{
  "name": "@soroban-license/backend",
  "version": "0.1.0",
  "description": "Soroban License REST API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node -r tsx/cjs src/db/migrate.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "12.3.0",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "express-validator": "7.1.0",
    "helmet": "7.1.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "pg": "8.12.0",
    "pino": "9.3.1",
    "pino-http": "10.2.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@types/uuid": "10.0.0",
    "eslint": "9.6.0",
    "jest": "29.7.0",
    "tsx": "4.16.2",
    "typescript": "5.5.3"
  }
